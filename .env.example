# GitHub App
ANAYA_GITHUB_APP_ID=123456
ANAYA_GITHUB_PRIVATE_KEY_PATH=./secrets/github-app.private-key.pem
ANAYA_GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Redis, needed by hosted GitHub App mode later
ANAYA_REDIS_URL=redis://localhost:6379/0

# Optional LLM fallback, disabled by default
ANAYA_OPENAI_API_KEY=your-openai-api-key

# Server, used by hosted app later
ANAYA_HOST=0.0.0.0
ANAYA_PORT=3000
ANAYA_LOG_LEVEL=INFO
